<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Taste.ViewModels"
             xmlns:viewmodels="clr-namespace:Taste.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Taste.MainPage"
             BackgroundColor="white"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">
        
        <toolkit:MediaElement x:Name="MusicPlayer"
                              Source="{Binding CurrentSongUrl}"
                              ShouldAutoPlay="True"
                              IsVisible="False" />

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20, 15, 20, 10">
            <Label Text="Taste" 
                   FontSize="28"
                   FontAttributes="Bold" 
                   TextColor="black" 
                   VerticalOptions="Center" />

            <HorizontalStackLayout Grid.Column="1" Spacing="20" VerticalOptions="Center">
                <ImageButton Source="search_icon.png" 
                             BackgroundColor="Transparent" 
                             HeightRequest="18" 
                             WidthRequest="18" 
                             Padding="2"
                             InputTransparent="False"
                             Command="{Binding ToggleSearchCommand}" />
                <ImageButton Source="create_icon.png" 
                             BackgroundColor="Transparent" 
                             HeightRequest="18" 
                             WidthRequest="18" 
                             Padding="2"/>
                <ImageButton Source="notification_icon.png" 
                             BackgroundColor="Transparent" 
                             HeightRequest="18" 
                             WidthRequest="18" 
                             Padding="2"/>
            </HorizontalStackLayout>
        </Grid>

        <CarouselView x:Name="SongCarouselView"
                      Grid.Row="1" 
                      ItemsSource="{Binding PublicStories}"
                      CurrentItemChanged="OnCarouselCurrentItemChanged"
                      Loop="False">

            <CarouselView.ItemTemplate>
                <DataTemplate>
                    <Grid HeightRequest="700" Padding="0" BackgroundColor="White">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> 
                            <RowDefinition Height="*" />    
                            <RowDefinition Height="Auto" /> 
                            <RowDefinition Height="Auto" /> 
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15, 10">
                            <Border Grid.Column="0" HeightRequest="40" WidthRequest="40" StrokeShape="RoundRectangle 20" StrokeThickness="0">
                                <Image Source="{Binding UserProfileImageUrl}" Aspect="AspectFill" />
                            </Border>

                            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                <Label Text="{Binding UserUsername}" FontSize="15" FontAttributes="Bold" TextColor="Black" />
                                <Label Text="{Binding PostTimeText}" FontSize="13" TextColor="#999999" />
                            </HorizontalStackLayout>

                            <ImageButton Grid.Column="2" 
                                         Source="more_icon.png" 
                                         BackgroundColor="Transparent" 
                                         HeightRequest="16" 
                                         WidthRequest="16" 
                                         Padding="2"
                                         VerticalOptions="Center" 
                                         Margin="0, 0, 10, 0"/>
                        </Grid>

                        <Border Grid.Row="1" Margin="15, 5, 15, 15" StrokeShape="RoundRectangle 10" StrokeThickness="1" Stroke="#E0E0E0" BackgroundColor="White">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.1" />
                            </Border.Shadow>
                            
                            <Grid RowDefinitions="*, Auto" Padding="15, 15, 15, 10">
                                <Border HeightRequest="300" WidthRequest="300" HorizontalOptions="Center" VerticalOptions="Start" 
                                        StrokeThickness="0" StrokeShape="RoundRectangle 2" Padding="2">
                                    <Image Source="{Binding UserUploadedImageUrl}" Aspect="AspectFill" />
                                </Border>

                                <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Padding="0, 15, 0, 0" ColumnSpacing="10">
                                    <VerticalStackLayout VerticalOptions="Center">
                                        <Label Text="{Binding TrackName}" FontSize="18" FontAttributes="Bold" TextColor="Black">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=OpenInSpotifyCommand}"
                                                                       CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <Label Text="{Binding ArtistName}" FontSize="14" TextColor="#666666">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=OpenArtistInSpotifyCommand}"
                                                                       CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </VerticalStackLayout>
                                    
                                    <HorizontalStackLayout Grid.Column="1" Spacing="15" VerticalOptions="Center">
                                        <ImageButton BackgroundColor="Transparent"
                                                     HeightRequest="18"
                                                     WidthRequest="18"
                                                     Padding="2"
                                                     Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=LikeStoryCommand}"
                                                     CommandParameter="{Binding .}">
                                            <ImageButton.Source>
                                                <FileImageSource File="heart_empty.png" />
                                            </ImageButton.Source>
                                            <ImageButton.Triggers>
                                                <DataTrigger TargetType="ImageButton" Binding="{Binding IsLiked}" Value="True">
                                                    <Setter Property="Source" Value="heart_red.png" />
                                                </DataTrigger>
                                            </ImageButton.Triggers>
                                        </ImageButton>

                                        <ImageButton BackgroundColor="Transparent"
                                                     HeightRequest="18"
                                                     WidthRequest="18"
                                                     Padding="2"
                                                     Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=AddToPlaylistCommand}"
                                                     CommandParameter="{Binding .}">
                                            <ImageButton.Source>
                                                <FileImageSource File="add_icon.png" />
                                            </ImageButton.Source>
                                            <ImageButton.Triggers>
                                                <DataTrigger TargetType="ImageButton" Binding="{Binding IsAddedToPlaylist}" Value="True">
                                                    <Setter Property="Source" Value="v_icon.png" />
                                                </DataTrigger>
                                            </ImageButton.Triggers>
                                        </ImageButton>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Padding="15, 0, 15, 10">
                            <HorizontalStackLayout Spacing="20">
                                <ImageButton BackgroundColor="Transparent" 
                                             HeightRequest="20" 
                                             WidthRequest="20" 
                                             Padding="2"
                                             VerticalOptions="Center"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=FireStoryCommand}"
                                             CommandParameter="{Binding .}">
                                    <ImageButton.Source>
                                        <FileImageSource File="fire_icon.png" />
                                    </ImageButton.Source>
                                    <ImageButton.Triggers>
                                        <DataTrigger TargetType="ImageButton" Binding="{Binding IsFired}" Value="True">
                                            <Setter Property="Source" Value="fired_icon.png" />
                                        </DataTrigger>
                                    </ImageButton.Triggers>
                                </ImageButton>

                                <ImageButton Source="comment_icon.png" BackgroundColor="Transparent" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" Padding="2"/>
                                <ImageButton Source="share_icon.png" BackgroundColor="Transparent" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" Padding="2"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <Grid Grid.Row="3" ColumnDefinitions="Auto, *" Padding="15, 0, 15, 15">
                            <Label Text="{Binding UserUsername}" FontSize="14" FontAttributes="Bold" TextColor="Black" VerticalOptions="Center" Padding="0,0,5,0"/>
                            <Label Grid.Column="1" Text="{Binding PostCaption}" FontSize="14" TextColor="Black" LineBreakMode="WordWrap" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <Grid Grid.Row="1" 
              BackgroundColor="White" 
              IsVisible="{Binding IsSearchMode}"
              RowDefinitions="Auto, *">
            
            <VerticalStackLayout Padding="20, 10" Spacing="10">
    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
        <Border Grid.Column="0" 
                StrokeShape="RoundRectangle 20" 
                StrokeThickness="1" 
                Stroke="#E0E0E0" 
                Padding="15,0"
                VerticalOptions="Center">
            <Entry Placeholder="Search for a song..." 
                   Text="{Binding SearchQuery, Mode=TwoWay}"
                   ReturnType="Search"
                   ReturnCommand="{Binding PerformSearchCommand}"
                   TextColor="Black"
                   PlaceholderColor="Gray" />
        </Border>

        <ImageButton Grid.Column="1" 
                     Source="cancel_icon.png" 
                     Command="{Binding ToggleSearchCommand}" 
                     BackgroundColor="Transparent" 
                     HeightRequest="18" 
                     WidthRequest="18" 
                     VerticalOptions="Center" />
    </Grid>
</VerticalStackLayout>

            <CollectionView Grid.Row="1" ItemsSource="{Binding SearchResults}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="20, 10" ColumnSpacing="15">
                            <Border StrokeShape="RoundRectangle 5" HeightRequest="50" WidthRequest="50" StrokeThickness="0">
                                <Image Source="{Binding AlbumImageUrl}" Aspect="AspectFill" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding TrackName}" FontAttributes="Bold" TextColor="Black" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding ArtistName}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Grid.Column="2" Spacing="10" VerticalOptions="Center">
                                <ImageButton BackgroundColor="#F0F0F0" 
                                             HeightRequest="28" 
                                             WidthRequest="28" 
                                             CornerRadius="14"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=PlaySongCommand}"
                                             CommandParameter="{Binding .}">
                                    <ImageButton.Source>
                                        <FileImageSource File="play_icon.png" />
                                    </ImageButton.Source>
                                    <ImageButton.Triggers>
                                        <DataTrigger TargetType="ImageButton" Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Source" Value="pause_icon.png" />
                                        </DataTrigger>
                                    </ImageButton.Triggers>
                                </ImageButton>
                                
                                <ImageButton Source="add_icon.png" 
                                             BackgroundColor="#1DB954" 
                                             HeightRequest="28" 
                                             WidthRequest="28" 
                                             CornerRadius="14"
                                             Padding="8"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=SelectTrackCommand}"
                                             CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>