<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Taste.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Taste.MainPage"
             BackgroundColor="white"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">
        
        <toolkit:MediaElement x:Name="MusicPlayer"
                              Source="{Binding CurrentSongUrl}"
                              ShouldAutoPlay="True"
                              IsVisible="False" />

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20, 15, 20, 10">
            <Label Text="Taste" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#1DB954" 
                   VerticalOptions="Center" />
            
            <HorizontalStackLayout Grid.Column="1" Spacing="20" VerticalOptions="Center">
                <Label Text="➕" FontSize="20" TextColor="White" />
                <Label Text="🔔" FontSize="20" TextColor="White" />
            </HorizontalStackLayout>
        </Grid>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding PublicStories}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid HeightRequest="650">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=PlaySongCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <Image Source="{Binding UserUploadedImageUrl}" 
                               Aspect="AspectFill" />

                        <BoxView VerticalOptions="Fill">
                            <BoxView.Background>
                                <LinearGradientBrush EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0.3" />
                                    <GradientStop Color="#99000000" Offset="0.7" />
                                    <GradientStop Color="Black" Offset="1" />
                                </LinearGradientBrush>
                            </BoxView.Background>
                        </BoxView>

                        <VerticalStackLayout VerticalOptions="End" Padding="20, 40" Spacing="15">
                            <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 12" WidthRequest="70" HeightRequest="70" StrokeThickness="0">
                                    <Image Source="{Binding AlbumImageUrl}" Aspect="AspectFill" />
                                </Border>

                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding TrackName}" FontSize="24" FontAttributes="Bold" TextColor="White" />
                                    <Label Text="{Binding ArtistName}" FontSize="16" TextColor="#CCCCCC" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Just now" TextColor="#999999" FontSize="13" VerticalOptions="Center" />
                                <HorizontalStackLayout Grid.Column="1" Spacing="25">
                                    <Button Text="❤️" BackgroundColor="Transparent" FontSize="26" Padding="0" />
                                    <Button Text="🔗" BackgroundColor="Transparent" FontSize="26" Padding="0" />
                                </HorizontalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>